---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found, ideeeas" description="That page does not exist." path="/404/">
  <section class="wrap-narrow py-28 text-center">
    <p class="font-display text-7xl font-extrabold text-spark">404</p>
    <h1 class="mt-4 font-display text-2xl font-bold text-ink">That idea wandered off</h1>
    <p class="mt-3 text-ink-soft">The page you wanted is not here, but the library is.</p>
    <a href="/ideas/" class="mt-8 inline-block rounded-full bg-ink text-paper font-semibold px-7 py-3.5 hover:bg-spark transition-colors">Browse all ideas</a>
  </section>
</Base>
