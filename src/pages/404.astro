---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found, ideeeas" description="That page does not exist." path="/404/">
  <section class="wrap-narrow py-32 text-center">
    <p class="font-display text-7xl font-extrabold grad-text glow">404</p>
    <h1 class="mt-6 font-display text-xl font-bold text-text"><span class="text-fog">$</span> idea: not found</h1>
    <p class="mt-3 text-text/80">The page you wanted is not here, but the library is.</p>
    <a href="/ideas/" class="btn-neon mt-8 inline-block px-7 py-3 rounded-md">browse all ideas →</a>
  </section>
</Base>
