---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found, ideeeas" description="That page does not exist." path="/404/">
  <section class="wrap-narrow py-32 text-center">
    <p class="font-display text-8xl font-bold text-ink inline-block mark">404</p>
    <h1 class="mt-6 font-display text-2xl font-bold text-ink">That idea wandered off</h1>
    <p class="mt-3 text-ink/80 font-medium">The page you wanted is not here, but the library is.</p>
    <a href="/ideas/" class="btn-pop mt-8 inline-block px-7 py-3.5">Browse all ideas</a>
  </section>
</Base>
