---
import Base from '../layouts/Base.astro';
import Subscribe from '../components/Subscribe.astro';
import { clusters, totalIdeas } from '../data/clusters.js';

const featured = clusters.slice(0, 6);

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ideeeas',
  url: 'https://ideeeas.com',
  description: 'A growing library of validated startup and side-project ideas, each with demand signals, difficulty, monetisation and a starter stack.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://ideeeas.com/ideas/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

import { pickColor } from '../data/palette.js';

const pillars = [
  ['Demand', 'Backed by a real, observable signal, not a hunch.'],
  ['Difficulty', 'Honest build effort and time to MVP.'],
  ['Money', 'A specific way it earns from day one.'],
  ['First step', 'The exact next move to validate it.'],
];
---
<Base path="/" jsonld={jsonld}>
  <!-- Hero -->
  <section class="wrap pt-16 sm:pt-24 pb-14">
    <div class="reveal in inline-flex items-center gap-2 brut bg-white px-3 py-1.5 text-xs font-bold uppercase tracking-wide text-ink shadow-hard-sm">
      <span class="h-2.5 w-2.5" style="background:var(--color-lime)"></span>
      Validated ideas, not idea spam
    </div>
    <h1 class="reveal in mt-6 font-display text-5xl sm:text-7xl font-bold leading-[1.0] text-ink max-w-4xl">
      Stop hunting for the idea. Start with a <span class="mark">validated</span> one.
    </h1>
    <p class="reveal in mt-7 text-xl text-ink/80 max-w-2xl leading-relaxed font-medium">
      {totalIdeas}+ startup and side-project ideas, each one with a real demand signal, build difficulty, how it makes money, and the first step you should take. No fluff, no get-rich-quick.
    </p>
    <div class="reveal in mt-9 flex flex-wrap gap-4">
      <a href="/ideas/" class="btn-pop px-7 py-3.5">Browse all ideas</a>
      <a href="#subscribe" class="btn-blk px-7 py-3.5">Get the weekly drop</a>
    </div>
  </section>

  <!-- How each idea is structured -->
  <section class="wrap py-8">
    <div class="grid gap-4 sm:grid-cols-4">
      {pillars.map(([t, d], i) => (
        <div class="reveal brut p-5 shadow-hard-sm" style={`background:${pickColor(i)}`}>
          <div class="font-display text-lg font-bold text-ink">{t}</div>
          <p class="mt-1.5 text-sm text-ink/80 font-medium">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured collections -->
  <section class="wrap py-14">
    <div class="flex items-end justify-between mb-8">
      <h2 class="reveal font-display text-3xl font-bold text-ink">Popular collections</h2>
      <a href="/ideas/" class="spark-link text-sm">See all {clusters.length} →</a>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((c, i) => (
        <a href={`/ideas/${c.slug}/`}
          class={`reveal press bg-white brut shadow-hard p-6 block ${i === 0 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
          <span class="inline-block brut px-2 py-1 text-xs font-bold uppercase tracking-wide text-ink" style={`background:${pickColor(i)}`}>{c.ideas.length} ideas · {c.audience}</span>
          <h3 class="mt-3 font-display text-xl font-bold text-ink">{c.title}</h3>
          <p class="mt-2 text-sm text-fog line-clamp-3">{c.intro}</p>
          <span class="mt-4 inline-block text-sm font-bold text-ink">Explore →</span>
        </a>
      ))}
    </div>
  </section>

  <Subscribe />
</Base>
