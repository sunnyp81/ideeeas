---
import Base from '../layouts/Base.astro';
import Subscribe from '../components/Subscribe.astro';
import { clusters, totalIdeas } from '../data/clusters.js';

const featured = clusters.slice(0, 6);

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ideeeas',
  url: 'https://ideeeas.com',
  description: 'A growing library of validated startup and side-project ideas, each with demand signals, difficulty, monetisation and a starter stack.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://ideeeas.com/ideas/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const collectionCount = clusters.length;

// ledger figures, padded for the tabular register signature
const total3 = String(totalIdeas).padStart(3, '0');
const collections2 = String(collectionCount).padStart(2, '0');
const dim = 'color-mix(in srgb, var(--color-fog) 55%, var(--color-term))';

// the four spec questions every entry answers, shown as a monochrome register
const pillars = [
  ['Demand', 'Backed by a real, observable signal, not a hunch.', '<path d="M3 17l5-5 4 4 8-8" /><path d="M16 8h5v5" />'],
  ['Difficulty', 'Honest build effort and a realistic time to MVP.', '<path d="M12 3v18" /><path d="M5 8l7-5 7 5" /><path d="M5 8v8l7 5 7-5V8" />'],
  ['Money', 'A specific way it earns from day one.', '<circle cx="12" cy="12" r="9" /><path d="M12 7v10M9.5 9.5h4a1.8 1.8 0 010 3.6h-3a1.8 1.8 0 000 3.6h4" />'],
  ['First step', 'The exact next move to validate it.', '<path d="M5 12h14" /><path d="M13 6l6 6-6 6" />'],
];
---
<Base path="/" jsonld={jsonld}>
  <!-- Hero -->
  <section class="wrap pt-16 sm:pt-24 pb-16 sm:pb-20">
    <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-14 lg:gap-12 items-center">
      <div>
        <div class="reveal in eyebrow eyebrow-pill"><span class="dot"></span> Validated ideas, not idea spam</div>
        <h1 class="reveal in mt-7 font-display font-semibold text-text leading-[1.02] tracking-[-0.03em] text-[clamp(3.25rem,6vw,5.5rem)]">
          Stop hunting for the idea. Start with a <span class="serif-i">validated</span> one.
        </h1>
        <p class="reveal in mt-7 text-lg text-soft max-w-xl leading-relaxed">
          {totalIdeas} startup and side-project ideas, each with a real demand signal, build difficulty, how it makes money, and the first step to take. No fluff, no get-rich-quick.
        </p>
        <div class="reveal in mt-9 flex flex-wrap gap-4">
          <a href="/ideas/" class="btn-neon px-7 py-3.5">Browse all ideas</a>
          <a href="#subscribe" class="btn-wire px-7 py-3.5">Get the weekly drop</a>
        </div>

        <!-- stat strip: mono ledger, tabular, monochrome restraint -->
        <div class="reveal in mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 font-mono text-sm tracking-[0.05em] text-fog" style="font-variant-numeric:tabular-nums">
          <span><span class="text-text font-semibold">{totalIdeas}</span> ideas</span>
          <span class="text-edge select-none">/</span>
          <span><span class="text-text font-semibold">{collectionCount}</span> collections</span>
          <span class="text-edge select-none">/</span>
          <span><span class="text-text font-semibold">Weekly</span> updates</span>
        </div>
      </div>

      <!-- Live sample entry: floating spec preview, solid surfaces, no blur -->
      <div class="reveal in panel p-6 sm:p-7">
        <!-- ledger top row: running index, leader rule, demand chip -->
        <div class="flex items-center gap-4">
          <span class="legend shrink-0">
            <span style="color:var(--color-fog)">001</span><span style={`color:${dim}`}> / {total3}</span>
          </span>
          <span class="rule flex-1"></span>
          <span class="inline-flex items-center gap-1.5 shrink-0 font-mono text-[0.7rem] tracking-[0.08em] uppercase"
            style="color:var(--color-high);background:rgba(70,177,123,0.10);border:1px solid var(--color-edge);border-radius:6px;padding:0.2rem 0.5rem">
            <span style="width:4px;height:4px;background:var(--color-high-dot)"></span> High demand
          </span>
        </div>

        <h3 class="mt-5 font-display text-2xl font-semibold text-text leading-tight tracking-[-0.015em]">Meeting-to-CRM autofill</h3>
        <p class="mt-3 text-sm text-soft leading-relaxed">Turn recorded sales calls into clean CRM records: fields, next steps and follow-up drafts, without reps typing a thing.</p>

        <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-5 text-sm border-t border-edge pt-6">
          <div>
            <dt class="eyebrow">Difficulty</dt>
            <dd class="mt-1.5 flex items-center gap-2">
              <span class="inline-flex items-center gap-1">
                <span style="width:5px;height:5px;display:inline-block;background:var(--color-soft)"></span>
                <span style="width:5px;height:5px;display:inline-block;background:var(--color-soft)"></span>
                <span style="width:5px;height:5px;display:inline-block;background:var(--color-edge-hi)"></span>
              </span>
              <span class="font-semibold text-text">Medium</span>
            </dd>
          </div>
          <div>
            <dt class="eyebrow">Time to MVP</dt>
            <dd class="mt-1.5 font-mono text-text" style="font-variant-numeric:tabular-nums">3-5 weeks</dd>
          </div>
          <div class="col-span-2">
            <dt class="eyebrow">How it makes money</dt>
            <dd class="mt-1.5 text-soft leading-relaxed">Per-seat SaaS at 25 to 40 dollars per user. Land one team, then expand by seat.</dd>
          </div>
        </dl>

        <div class="mt-6 flex flex-wrap gap-2">
          {['Next.js', 'Whisper API', 'LLM extraction', 'HubSpot'].map((s) => <span class="chip">{s}</span>)}
        </div>
      </div>
    </div>
  </section>

  <div class="wrap"><div class="rule"></div></div>

  <!-- The anatomy of an idea: monochrome register of the four spec questions -->
  <section class="wrap py-16 sm:py-20">
    <div class="reveal max-w-2xl">
      <div class="legend">S.01 / THE ANATOMY OF AN IDEA</div>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold text-text tracking-[-0.02em]">Every idea, structured the same way</h2>
      <p class="mt-3 text-soft leading-relaxed">No idea-of-the-week noise. Each entry answers the four questions that actually decide whether to build.</p>
    </div>
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {pillars.map(([t, d, icon], i) => (
        <div class="reveal card card-hover accent-top p-6">
          <div class="flex items-center justify-between">
            <span class="legend"><span style="color:var(--color-fog)">{String(i + 1).padStart(2, '0')}</span><span style={`color:${dim}`}> / 04</span></span>
            <div class="icon-box">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icon}></svg>
            </div>
          </div>
          <div class="mt-5 font-display text-lg font-semibold text-text tracking-[-0.015em]">{t}</div>
          <p class="mt-1.5 text-sm text-fog leading-relaxed">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Popular collections: strict register grid -->
  <section class="wrap pb-20">
    <div class="flex items-end justify-between mb-10 gap-6">
      <div class="reveal">
        <div class="legend">S.02 / {collections2} COLLECTIONS</div>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold text-text tracking-[-0.02em]">Popular collections</h2>
      </div>
      <a href="/ideas/" class="spark-link text-sm shrink-0 whitespace-nowrap">See all {collectionCount} &rarr;</a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((c, i) => (
        <a href={`/ideas/${c.slug}/`} class="reveal card card-hover accent-top p-6 block group">
          <!-- ledger top row: index, leader rule -->
          <div class="flex items-center gap-4">
            <span class="legend shrink-0"><span style="color:var(--color-fog)">{String(i + 1).padStart(2, '0')}</span><span style={`color:${dim}`}> / {collections2}</span></span>
            <span class="rule flex-1"></span>
          </div>
          <h3 class="mt-5 font-display text-xl font-semibold text-text tracking-[-0.015em]">{c.title}</h3>
          <p class="mt-2 text-sm text-fog line-clamp-3 leading-relaxed">{c.intro}</p>
          <div class="mt-6 flex items-center justify-between">
            <span class="font-mono text-[0.7rem] tracking-[0.05em] text-fog" style="font-variant-numeric:tabular-nums">{String(c.ideas.length).padStart(2, '0')} ideas</span>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-soft">Explore <span class="transition-transform duration-200 group-hover:translate-x-1">&rarr;</span></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Subscribe />
</Base>
