---
import Base from '../../layouts/Base.astro';
import IdeaCard from '../../components/IdeaCard.astro';
import Subscribe from '../../components/Subscribe.astro';
import { clusters } from '../../data/clusters.js';
import { pickNeon } from '../../data/neon.js';

export function getStaticPaths() {
  return clusters.map((c, i) => ({ params: { slug: c.slug }, props: { cluster: c, accent: pickNeon(i) } }));
}

const { cluster, accent } = Astro.props;
const path = `/ideas/${cluster.slug}/`;
const url = new URL(path, Astro.site).href;

const others = clusters.filter((c) => c.slug !== cluster.slug).slice(0, 4);

const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: cluster.h1,
      description: cluster.seoDescription,
      datePublished: cluster.updated,
      dateModified: cluster.updated,
      mainEntityOfPage: url,
      author: { '@type': 'Organization', name: 'ideeeas' },
      publisher: { '@type': 'Organization', name: 'ideeeas' },
    },
    {
      '@type': 'ItemList',
      name: cluster.title,
      numberOfItems: cluster.ideas.length,
      itemListElement: cluster.ideas.map((idea, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: idea.name,
        description: idea.pitch,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Ideas', item: new URL('/ideas/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: cluster.title, item: url },
      ],
    },
  ],
};
---
<Base title={cluster.seoTitle} description={cluster.seoDescription} path={path} jsonld={jsonld}>
  <div class="wrap pt-16 sm:pt-20">
    <nav class="text-sm text-fog mb-6">
      <a href="/ideas/" class="hover:text-cyan transition-colors">ideas</a> <span class="mx-1 text-fog/60">/</span>
      <span class="text-text">{cluster.slug}</span>
    </nav>

    <header class="max-w-3xl">
      <p class="reveal in text-sm font-display glow" style={`color:${accent}`}>
        {cluster.ideas.length} validated ideas · for {cluster.audience}
      </p>
      <h1 class="reveal in mt-3 font-display text-3xl sm:text-5xl font-extrabold leading-tight text-text">{cluster.h1}</h1>
      <p class="reveal in mt-5 text-lg text-text/80 leading-relaxed">{cluster.intro}</p>
      <p class="reveal in mt-4 text-sm text-fog"><span style={`color:${accent}`}>//</span> last reviewed {cluster.updated}. Every idea is a starting point, validate demand before you build.</p>
    </header>
  </div>

  <div class="wrap mt-10 grid gap-6 lg:grid-cols-2">
    {cluster.ideas.map((idea, i) => <IdeaCard idea={idea} n={i + 1} />)}
  </div>

  <Subscribe />

  <section class="wrap mb-20">
    <h2 class="font-display text-xl font-bold mb-6 text-text"><span class="grad-text">#</span> more idea collections</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {others.map((c, i) => (
        <a href={`/ideas/${c.slug}/`} class="reveal term-box term-hover p-5 block" style={`--c:${pickNeon(i + 3)}`}>
          <div class="font-display font-bold text-text">{c.title}</div>
          <div class="text-sm text-fog mt-1">{c.ideas.length} ideas for {c.audience}</div>
        </a>
      ))}
    </div>
  </section>
</Base>
