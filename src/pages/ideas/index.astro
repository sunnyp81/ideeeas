---
import Base from '../../layouts/Base.astro';
import { clusters, totalIdeas } from '../../data/clusters.js';

const path = '/ideas/';
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'All idea collections',
  description: `Browse ${totalIdeas} validated startup and side-project ideas across ${clusters.length} collections.`,
  url: new URL(path, Astro.site).href,
};
---
<Base
  title={`All Idea Collections, ${totalIdeas} Validated Ideas | ideeeas`}
  description={`Browse ${totalIdeas} validated startup and side-project ideas across ${clusters.length} collections, each with demand, difficulty, monetisation and a starter stack.`}
  path={path}
  jsonld={jsonld}
>
  <div class="wrap pt-16 sm:pt-20">
    <div class="text-sm text-fog prompt">ls ./ideas</div>
    <h1 class="reveal in mt-4 font-display text-3xl sm:text-5xl font-extrabold text-text">Every <span class="amber">idea</span> collection</h1>
    <p class="reveal in mt-4 text-text/80 max-w-2xl leading-relaxed">
      {totalIdeas} validated ideas across {clusters.length} collections. Each one is structured the same way, demand, difficulty, how it makes money, and the first step.
    </p>
  </div>

  <div class="wrap mt-10 mb-24 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {clusters.map((c) => (
      <a href={`/ideas/${c.slug}/`} class="reveal term-box term-hover p-6 block">
        <div class="text-xs text-fog"><span class="green">{String(c.ideas.length).padStart(2, '0')}</span> ideas · {c.audience}</div>
        <h2 class="mt-2 font-display text-lg font-bold text-text">{c.title}</h2>
        <p class="mt-2 text-sm text-fog line-clamp-3 leading-relaxed">{c.intro}</p>
      </a>
    ))}
  </div>
</Base>
