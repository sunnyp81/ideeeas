---
// StaticForms capture (shared portfolio key; client-side by design). _site tag = source attribution.
const accessKey = 'sf_9e906eb6c00416b9d3354749';
---
<section id="subscribe" class="wrap-narrow my-24 scroll-mt-24">
  <div class="reveal term-box p-8 sm:p-10 overflow-hidden" style="--c:var(--color-magenta)">
    <div class="pointer-events-none absolute -top-24 right-[-10%] h-56 w-[34rem] blur-3xl opacity-50"
      style="background: radial-gradient(closest-side, rgba(255,46,151,0.5), transparent);"></div>
    <span class="legend font-display">subscribe.sh</span>
    <div class="relative">
      <h2 class="font-display text-2xl font-bold text-text"><span style="color:var(--color-mint)">$</span> get <span class="grad-text glow">10 validated ideas</span> / week<span class="caret ml-1"></span></h2>
      <p class="mt-3 text-fog leading-relaxed text-sm max-w-xl">
        One email, every Friday: fresh startup and side-project ideas with demand signals and a starter stack. No spam, unsubscribe in one click.
      </p>
      <form action="https://api.staticforms.xyz/submit" method="POST" class="mt-6 flex flex-col sm:flex-row gap-3 max-w-md">
        <input type="hidden" name="accessKey" value={accessKey} />
        <input type="hidden" name="subject" value="ideeeas.com, new subscriber" />
        <input type="hidden" name="_site" value="ideeeas.com" />
        <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off" />
        <input
          type="email"
          name="email"
          required
          placeholder="you@email.com"
          class="flex-1 bg-panel text-text px-4 py-2.5 rounded-md placeholder:text-fog focus:outline-none"
          style="border:1px solid color-mix(in srgb, var(--color-cyan) 35%, transparent)"
        />
        <button type="submit" class="btn-neon px-5 py-2.5 rounded-md">subscribe</button>
      </form>
    </div>
  </div>
</section>
