---
// StaticForms capture (shared portfolio key; client-side by design). _site tag = source attribution.
const accessKey = 'sf_9e906eb6c00416b9d3354749';
---
<section id="subscribe" class="wrap-narrow my-24 scroll-mt-24">
  <div class="reveal brut shadow-hard-lg p-8 sm:p-12 text-center" style="background:var(--color-sky)">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink">Get 10 validated ideas every week</h2>
    <p class="mt-3 text-ink/80 max-w-xl mx-auto font-medium">
      One email, every Friday: fresh startup and side-project ideas with demand signals and a starter stack. No spam, unsubscribe in one click.
    </p>
    <form action="https://api.staticforms.xyz/submit" method="POST" class="mt-7 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input type="hidden" name="accessKey" value={accessKey} />
      <input type="hidden" name="subject" value="ideeeas.com, new subscriber" />
      <input type="hidden" name="_site" value="ideeeas.com" />
      <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off" />
      <input
        type="email"
        name="email"
        required
        placeholder="you@email.com"
        class="flex-1 brut bg-white px-5 py-3 text-ink placeholder:text-fog focus:outline-none focus:bg-yellow"
      />
      <button type="submit" class="btn-blk px-6 py-3">Subscribe free</button>
    </form>
  </div>
</section>
