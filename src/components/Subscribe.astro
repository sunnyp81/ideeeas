---
// StaticForms capture (shared portfolio key; client-side by design). _site tag = source attribution.
const accessKey = 'sf_9e906eb6c00416b9d3354749';
---
<section id="subscribe" class="wrap-narrow my-24 scroll-mt-24">
  <div class="reveal relative overflow-hidden rounded-3xl glass p-8 sm:p-12 text-center">
    <div class="pointer-events-none absolute -top-24 left-1/2 -translate-x-1/2 h-56 w-[40rem] rounded-full blur-3xl"
      style="background: radial-gradient(closest-side, rgba(124,92,255,0.45), transparent);"></div>
    <div class="relative">
      <h2 class="font-display text-3xl font-extrabold text-snow">Get 10 validated ideas every week</h2>
      <p class="mt-3 text-fog max-w-xl mx-auto">
        One email, every Friday: fresh startup and side-project ideas with demand signals and a starter stack. No spam, unsubscribe in one click.
      </p>
      <form action="https://api.staticforms.xyz/submit" method="POST" class="mt-7 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="hidden" name="accessKey" value={accessKey} />
        <input type="hidden" name="subject" value="ideeeas.com, new subscriber" />
        <input type="hidden" name="_site" value="ideeeas.com" />
        <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off" />
        <input
          type="email"
          name="email"
          required
          placeholder="you@email.com"
          class="flex-1 rounded-full px-5 py-3 text-snow bg-white/6 border border-white/12 placeholder:text-fog focus:outline-none focus:ring-2 focus:ring-violet/60"
        />
        <button type="submit" class="btn-grad rounded-full px-6 py-3">Subscribe free</button>
      </form>
    </div>
  </div>
</section>
