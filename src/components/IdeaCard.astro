---
import { pickNeon } from '../data/neon.js';
const { idea, n } = Astro.props;
const c = pickNeon(n - 1);

const demand = {
  High: ['var(--color-mint)', 'HIGH'],
  Medium: ['var(--color-yellow)', 'MED'],
  Emerging: ['var(--color-magenta)', 'NEW'],
}[idea.demand] || ['var(--color-fog)', '—'];

const diffN = { Low: 1, Medium: 2, High: 3 }[idea.difficulty] || 0;
const meter = '█'.repeat(diffN) + '░'.repeat(3 - diffN);
const id = String(n).padStart(2, '0');
---
<article class="reveal term-box term-hover p-6 sm:p-7 text-sm" style={`--c:${c}`}>
  <span class="legend font-display">idea_{id}</span>

  <div class="flex items-start justify-between gap-4 mt-1">
    <h3 class="font-display text-lg font-bold text-text">{idea.name}</h3>
    <span class="shrink-0 font-display text-xs glow" style={`color:${demand[0]}`}>[{demand[1]}]</span>
  </div>

  <p class="mt-3 text-text/85 leading-relaxed">{idea.pitch}</p>

  <p class="mt-3 text-fog"><span style={`color:${c}`}>// problem:</span> {idea.problem}</p>

  <dl class="mt-5 grid grid-cols-2 gap-x-6 gap-y-3" style="border-top:1px solid rgba(140,140,180,0.14); padding-top:1.1rem">
    <div>
      <dt class="text-fog text-xs">difficulty</dt>
      <dd class="font-bold"><span class="tracking-widest glow" style={`color:${c}`}>{meter}</span> <span class="text-text">{idea.difficulty}</span></dd>
    </div>
    <div>
      <dt class="text-fog text-xs">time_to_mvp</dt>
      <dd class="font-bold text-text">{idea.timeToMvp}</dd>
    </div>
    <div class="col-span-2">
      <dt class="text-fog text-xs">revenue</dt>
      <dd class="text-text/90">{idea.monetisation}</dd>
    </div>
    <div class="col-span-2">
      <dt class="text-fog text-xs">first_step</dt>
      <dd class="text-text/90">{idea.firstStep}</dd>
    </div>
  </dl>

  <div class="mt-5 flex flex-wrap items-center gap-2">
    {idea.stack.map((s) => (
      <span class="chip px-2 py-0.5 text-xs rounded">{s}</span>
    ))}
  </div>

  {idea.tools?.length > 0 && (
    <p class="mt-4 text-fog text-xs">
      <span style={`color:${c}`}>$</span> build_with{' '}
      {idea.tools.map((t, i) => (
        <>
          <a href={t.url} rel="nofollow sponsored noopener noreferrer" target="_blank" class="spark-link">{t.name}</a>{i < idea.tools.length - 1 ? ' ' : ''}
        </>
      ))}
    </p>
  )}
</article>
