---
const { idea, n } = Astro.props;

const demandColor = {
  High: 'bg-grow/12 text-grow ring-grow/25',
  Medium: 'bg-amber/12 text-amber ring-amber/25',
  Emerging: 'bg-spark/12 text-spark ring-spark/25',
}[idea.demand] || 'bg-white/5 text-fog ring-white/10';

const diffColor = {
  Low: 'text-grow',
  Medium: 'text-amber',
  High: 'text-spark',
}[idea.difficulty] || 'text-fog';
---
<article class="reveal glass glass-hover rounded-2xl p-6 sm:p-7">
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-display text-xl font-bold text-snow">
      <span class="grad-text mr-2">{String(n).padStart(2, '0')}</span>{idea.name}
    </h3>
    <span class={`shrink-0 rounded-full px-3 py-1 text-xs font-semibold ring-1 ${demandColor}`}>
      {idea.demand} demand
    </span>
  </div>

  <p class="mt-3 text-snow/85 leading-relaxed">{idea.pitch}</p>

  <p class="mt-3 text-sm text-fog"><span class="font-semibold text-snow/90">The problem:</span> {idea.problem}</p>

  <dl class="mt-5 grid grid-cols-2 gap-x-6 gap-y-3 text-sm border-t border-white/8 pt-5">
    <div>
      <dt class="text-fog">Difficulty</dt>
      <dd class={`font-semibold ${diffColor}`}>{idea.difficulty}</dd>
    </div>
    <div>
      <dt class="text-fog">Time to MVP</dt>
      <dd class="font-semibold text-snow">{idea.timeToMvp}</dd>
    </div>
    <div class="col-span-2">
      <dt class="text-fog">How it makes money</dt>
      <dd class="font-medium text-snow/90">{idea.monetisation}</dd>
    </div>
    <div class="col-span-2">
      <dt class="text-fog">First step</dt>
      <dd class="font-medium text-snow/90">{idea.firstStep}</dd>
    </div>
  </dl>

  <div class="mt-5 flex flex-wrap items-center gap-2">
    {idea.stack.map((s) => (
      <span class="rounded-md bg-white/4 border border-white/8 px-2 py-1 text-xs text-fog">{s}</span>
    ))}
  </div>

  {idea.tools?.length > 0 && (
    <p class="mt-4 text-sm text-fog">
      Build it with{' '}
      {idea.tools.map((t, i) => (
        <>
          <a href={t.url} rel="nofollow sponsored noopener noreferrer" target="_blank" class="spark-link">{t.name}</a>{i < idea.tools.length - 1 ? ', ' : ''}
        </>
      ))}
    </p>
  )}
</article>
