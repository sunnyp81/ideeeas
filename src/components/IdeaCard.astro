---
import { pickColor } from '../data/palette.js';
const { idea, n } = Astro.props;
const accent = pickColor(n - 1);

const demandBg = { High: '#bdf24e', Medium: '#ffe14d', Emerging: '#ff8fb1' }[idea.demand] || '#ffffff';
---
<article class="reveal press-lg bg-white brut shadow-hard rounded-none p-6 sm:p-7">
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-display text-xl font-bold text-ink flex items-center gap-3">
      <span class="inline-flex items-center justify-center h-9 w-9 brut text-sm font-bold" style={`background:${accent}`}>{String(n).padStart(2, '0')}</span>
      {idea.name}
    </h3>
    <span class="shrink-0 brut px-3 py-1 text-xs font-bold text-ink" style={`background:${demandBg}`}>
      {idea.demand.toUpperCase()} DEMAND
    </span>
  </div>

  <p class="mt-4 text-ink leading-relaxed">{idea.pitch}</p>

  <p class="mt-3 text-sm text-fog"><span class="font-bold text-ink">The problem:</span> {idea.problem}</p>

  <dl class="mt-5 grid grid-cols-2 gap-x-6 gap-y-3 text-sm" style="border-top:2px solid var(--color-ink); padding-top:1.25rem">
    <div>
      <dt class="text-fog font-semibold uppercase text-xs tracking-wide">Difficulty</dt>
      <dd class="font-bold text-ink">{idea.difficulty}</dd>
    </div>
    <div>
      <dt class="text-fog font-semibold uppercase text-xs tracking-wide">Time to MVP</dt>
      <dd class="font-bold text-ink">{idea.timeToMvp}</dd>
    </div>
    <div class="col-span-2">
      <dt class="text-fog font-semibold uppercase text-xs tracking-wide">How it makes money</dt>
      <dd class="font-medium text-ink">{idea.monetisation}</dd>
    </div>
    <div class="col-span-2">
      <dt class="text-fog font-semibold uppercase text-xs tracking-wide">First step</dt>
      <dd class="font-medium text-ink">{idea.firstStep}</dd>
    </div>
  </dl>

  <div class="mt-5 flex flex-wrap items-center gap-2">
    {idea.stack.map((s) => (
      <span class="chip px-2 py-1 text-xs text-ink">{s}</span>
    ))}
  </div>

  {idea.tools?.length > 0 && (
    <p class="mt-4 text-sm text-fog">
      Build it with{' '}
      {idea.tools.map((t, i) => (
        <>
          <a href={t.url} rel="nofollow sponsored noopener noreferrer" target="_blank" class="spark-link">{t.name}</a>{i < idea.tools.length - 1 ? ', ' : ''}
        </>
      ))}
    </p>
  )}
</article>
