---
import { pickNeon } from '../data/neon.js';
const { idea, n } = Astro.props;
const c = pickNeon(n - 1);

const demand = {
  High: ['var(--color-mint)', 'High demand'],
  Medium: ['var(--color-yellow)', 'Medium demand'],
  Emerging: ['var(--color-violet)', 'Emerging'],
}[idea.demand] || ['var(--color-fog)', '—'];

const diffN = { Low: 1, Medium: 2, High: 3 }[idea.difficulty] || 0;
const dots = '●'.repeat(diffN) + '○'.repeat(3 - diffN);
const id = String(n).padStart(2, '0');
---
<article class="reveal term-box term-hover accent-top p-6 sm:p-7" style={`--c:${c}`}>
  <div class="flex items-start justify-between gap-4">
    <div>
      <span class="legend">Idea {id}</span>
      <h3 class="font-display text-2xl font-semibold text-text leading-tight">{idea.name}</h3>
    </div>
    <span class="shrink-0 text-xs font-semibold mt-1" style={`color:${demand[0]}`}>{demand[1]}</span>
  </div>

  <p class="mt-4 text-text/85 leading-relaxed">{idea.pitch}</p>

  <p class="mt-3 text-sm text-fog"><span class="font-semibold text-text/90">The problem.</span> {idea.problem}</p>

  <dl class="mt-5 grid grid-cols-2 gap-x-6 gap-y-4 text-sm" style="border-top:1px solid rgba(150,165,190,0.12); padding-top:1.25rem">
    <div>
      <dt class="eyebrow text-fog" style="color:var(--color-fog)">Difficulty</dt>
      <dd class="mt-1 font-semibold"><span class="tracking-[0.2em]" style={`color:${c}`}>{dots}</span> <span class="text-text">{idea.difficulty}</span></dd>
    </div>
    <div>
      <dt class="eyebrow text-fog" style="color:var(--color-fog)">Time to MVP</dt>
      <dd class="mt-1 font-semibold text-text">{idea.timeToMvp}</dd>
    </div>
    <div class="col-span-2">
      <dt class="eyebrow text-fog" style="color:var(--color-fog)">How it makes money</dt>
      <dd class="mt-1 text-text/90">{idea.monetisation}</dd>
    </div>
    <div class="col-span-2">
      <dt class="eyebrow text-fog" style="color:var(--color-fog)">First step</dt>
      <dd class="mt-1 text-text/90">{idea.firstStep}</dd>
    </div>
  </dl>

  <div class="mt-5 flex flex-wrap items-center gap-2">
    {idea.stack.map((s) => (
      <span class="chip px-2.5 py-1 text-xs">{s}</span>
    ))}
  </div>

  {idea.tools?.length > 0 && (
    <p class="mt-4 text-sm text-fog">
      Build it with{' '}
      {idea.tools.map((t, i) => (
        <>
          <a href={t.url} rel="nofollow sponsored noopener noreferrer" target="_blank" class="spark-link">{t.name}</a>{i < idea.tools.length - 1 ? ', ' : ''}
        </>
      ))}
    </p>
  )}
</article>
